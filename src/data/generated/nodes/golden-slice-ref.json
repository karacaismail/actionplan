  "ecaRules": [
    {
      "id": "eca-golden-slice-ref-done",
      "event": "task.status.changed",
      "when": [
        {
          "field": "status",
          "op": "eq",
          "value": "done"
        }
      ],
      "then": {
        "type": "notify",
        "params": {
          "target": "owner",
          "message": "ArcheType — Backend örnek kırılımı tamamlandı"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-golden-slice-ref-blocked",
      "event": "task.status.changed",
      "when": [
        {
          "field": "status",
          "op": "eq",
          "value": "blocked"
        }
      ],
      "then": {
        "type": "create-task",
        "params": {
          "title": "ArcheType — Backend örnek kırılımı blokajını çöz",
          "priority": "high"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-golden-slice-ref-complete",
      "event": "task.progress.changed",
      "when": [
        {
          "field": "progress",
          "op": "gte",
          "value": 100
        }
      ],
      "then": {
        "type": "set-field",
        "params": {
          "field": "status",
          "value": "done"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-golden-slice-ref-ai-app-module-deny",
      "event": "ai.generation.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "in",
          "value": [
            "app",
            "module"
          ]
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "ai-cannot-generate-app-or-module",
          "node": "app-backend-x-archetype"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-golden-slice-ref-ai-app-module-update-deny",
      "event": "ai.update.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "in",
          "value": [
            "app",
            "module"
          ]
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "ai-cannot-update-app-or-module",
          "node": "app-backend-x-archetype"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-golden-slice-ref-ruleset-override-deny",
      "event": "ai.ruleset.override.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "ai-cannot-override-rulesets",
          "node": "app-backend-x-archetype"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-golden-slice-ref-risk-quarantine",
      "event": "ai.risk.scored",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "riskScore",
          "op": "gte",
          "value": 80
        }
      ],
      "then": {
        "type": "create-task",
        "params": {
          "title": "ArcheType — Backend örnek kırılımı AI risk incelemesi",
          "priority": "critical"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": true
    },
    {
      "id": "eca-golden-slice-ref-archetype-draft-allow",
      "event": "ai.archetype.generate.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "eq",
          "value": "archetype"
        },
        {
          "field": "environment",
          "op": "in",
          "value": [
            "draft",
            "staging"
          ]
        }
      ],
      "then": {
        "type": "create-archetype-draft",
        "params": {
          "node": "app-backend-x-archetype",
          "level": "archetype"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": true
    },
    {
      "id": "eca-golden-slice-ref-archetype-prod-history-deny",
      "event": "ai.archetype.update.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "eq",
          "value": "archetype"
        },
        {
          "field": "environment",
          "op": "eq",
          "value": "production"
        },
        {
          "field": "historyPreserved",
          "op": "neq",
          "value": true
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "prod-archetype-update-must-preserve-history",
          "node": "app-backend-x-archetype"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-golden-slice-ref-archetype-prod-update-gated",
      "event": "ai.archetype.update.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "eq",
          "value": "archetype"
        },
        {
          "field": "environment",
          "op": "eq",
          "value": "production"
        },
        {
          "field": "historyPreserved",
          "op": "eq",
          "value": true
        },
        {
          "field": "snapshotCreated",
          "op": "eq",
          "value": true
        },
        {
          "field": "rollbackReady",
          "op": "eq",
          "value": true
        },
        {
          "field": "compatibilityChecked",
          "op": "eq",
          "value": true
        },
        {
          "field": "migrationMode",
          "op": "in",
          "value": [
            "append-only",
            "expand-contract"
          ]
        }
      ],
      "then": {
        "type": "propose-archetype-prod-update",
        "params": {
          "node": "app-backend-x-archetype",
          "history": "preserved"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": true
    }
  ],
