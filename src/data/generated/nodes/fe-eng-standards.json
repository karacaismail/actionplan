  "ecaRules": [
    {
      "id": "eca-fe-eng-standards-done",
      "event": "task.status.changed",
      "when": [
        {
          "field": "status",
          "op": "eq",
          "value": "done"
        }
      ],
      "then": {
        "type": "notify",
        "params": {
          "target": "owner",
          "message": "ADR-0001: Repo Konumu — bağımsız private repo tamamlandı"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-fe-eng-standards-blocked",
      "event": "task.status.changed",
      "when": [
        {
          "field": "status",
          "op": "eq",
          "value": "blocked"
        }
      ],
      "then": {
        "type": "create-task",
        "params": {
          "title": "ADR-0001: Repo Konumu — bağımsız private repo blokajını çöz",
          "priority": "high"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-fe-eng-standards-complete",
      "event": "task.progress.changed",
      "when": [
        {
          "field": "progress",
          "op": "gte",
          "value": 100
        }
      ],
      "then": {
        "type": "set-field",
        "params": {
          "field": "status",
          "value": "done"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-fe-eng-standards-ai-app-module-deny",
      "event": "ai.generation.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "in",
          "value": [
            "app",
            "module"
          ]
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "ai-cannot-generate-app-or-module",
          "node": "adr-0001"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-fe-eng-standards-ai-app-module-update-deny",
      "event": "ai.update.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "in",
          "value": [
            "app",
            "module"
          ]
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "ai-cannot-update-app-or-module",
          "node": "adr-0001"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-fe-eng-standards-ruleset-override-deny",
      "event": "ai.ruleset.override.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "ai-cannot-override-rulesets",
          "node": "adr-0001"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-fe-eng-standards-risk-quarantine",
      "event": "ai.risk.scored",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "riskScore",
          "op": "gte",
          "value": 80
        }
      ],
      "then": {
        "type": "create-task",
        "params": {
          "title": "ADR-0001: Repo Konumu — bağımsız private repo AI risk incelemesi",
          "priority": "critical"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": true
    }
  ],
