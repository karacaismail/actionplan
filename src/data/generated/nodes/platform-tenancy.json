    {
      "id": "eca-platform-tenancy-complete",
      "event": "task.progress.changed",
      "when": [
        {
          "field": "progress",
          "op": "gte",
          "value": 100
        }
      ],
      "then": {
        "type": "set-field",
        "params": {
          "field": "status",
          "value": "done"
        }
      },
      "maxChainDepth": 6,
      "requiresApproval": false
    },
    {
      "id": "eca-platform-tenancy-ai-app-module-deny",
      "event": "ai.generation.requested",
      "when": [
        {
          "field": "actor",
          "op": "eq",
          "value": "ai"
        },
        {
          "field": "targetLevel",
          "op": "in",
          "value": [
            "app",
            "module"
          ]
        }
      ],
      "then": {
        "type": "deny",
        "params": {
          "reason": "ai-cannot-generate-app-or-module",
