[
  {
    "id": "rs-status-notify",
    "name": "Durum Bildirimi",
    "description": "Görev durumu done/blocked olduğunda ilgili sahibe bildirim gönderir. Yalnız bildirir, veri yazmaz.",
    "layer": "platform",
    "category": "notification",
    "version": "1.0.0",
    "params": [
      {
        "key": "target",
        "label": "Bildirim hedefi",
        "type": "string",
        "default": "owner",
        "tenantEditable": true
      }
    ],
    "rules": [
      {
        "id": "rs-status-notify-done",
        "event": "task.status.changed",
        "when": [{ "field": "status", "op": "eq", "value": "done" }],
        "then": {
          "type": "notify",
          "params": { "target": "owner", "message": "Görev tamamlandı" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      },
      {
        "id": "rs-status-notify-blocked",
        "event": "task.status.changed",
        "when": [{ "field": "status", "op": "eq", "value": "blocked" }],
        "then": {
          "type": "notify",
          "params": { "target": "owner", "message": "Görev bloke oldu" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": false,
      "requiresApproval": false,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": [], "levels": [] }
  },
  {
    "id": "rs-blocked-resolver",
    "name": "Blokaj Çözücü",
    "description": "Görev bloke olduğunda çözüm için yüksek öncelikli bir alt-görev oluşturur.",
    "layer": "platform",
    "category": "lifecycle",
    "version": "1.0.0",
    "params": [
      {
        "key": "priority",
        "label": "Oluşturulan görev önceliği",
        "type": "string",
        "default": "high",
        "tenantEditable": true
      }
    ],
    "rules": [
      {
        "id": "rs-blocked-resolver-create",
        "event": "task.status.changed",
        "when": [{ "field": "status", "op": "eq", "value": "blocked" }],
        "then": { "type": "create-task", "params": { "title": "Blokajı çöz", "priority": "high" } },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": true,
      "requiresApproval": false,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": [], "levels": [] }
  },
  {
    "id": "rs-sla-escalation",
    "name": "SLA Tırmandırma",
    "description": "Görev belirlenen süreyi aştığında yöneticiye tırmandırma bildirimi gönderir.",
    "layer": "platform",
    "category": "escalation",
    "version": "1.0.0",
    "params": [
      {
        "key": "slaHours",
        "label": "SLA süresi (saat)",
        "type": "number",
        "default": 48,
        "tenantEditable": true
      },
      {
        "key": "escalateTo",
        "label": "Tırmandırma hedefi",
        "type": "string",
        "default": "manager",
        "tenantEditable": true
      }
    ],
    "rules": [
      {
        "id": "rs-sla-escalation-overdue",
        "event": "task.sla.elapsed",
        "when": [{ "field": "overdue", "op": "eq", "value": true }],
        "then": {
          "type": "notify",
          "params": { "target": "manager", "message": "SLA aşıldı; tırmandırılıyor" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": false,
      "requiresApproval": false,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": {
      "clusters": ["core-operations", "customer-revenue", "platform-horizontal"],
      "levels": []
    }
  },
  {
    "id": "rs-stale-reminder",
    "name": "Durağan Görev Hatırlatıcı",
    "description": "Belirli gün ilerleme olmayan göreve sahibine hatırlatma gönderir.",
    "layer": "platform",
    "category": "notification",
    "version": "1.0.0",
    "params": [
      {
        "key": "staleDays",
        "label": "Durağanlık eşiği (gün)",
        "type": "number",
        "default": 7,
        "tenantEditable": true
      }
    ],
    "rules": [
      {
        "id": "rs-stale-reminder-fire",
        "event": "task.idle.elapsed",
        "when": [{ "field": "idleDays", "op": "gte", "value": 7 }],
        "then": {
          "type": "notify",
          "params": { "target": "owner", "message": "Bu görevde ilerleme durdu" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": false,
      "requiresApproval": false,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": [], "levels": [] }
  },
  {
    "id": "rs-approval-workflow",
    "name": "Onay Akışı",
    "description": "Görev onaya gönderildiğinde onay görevi oluşturur; onaylandığında ilerlemeyi serbest bırakır. Uygula adımı insan onayı gerektirir.",
    "layer": "platform",
    "category": "approval",
    "version": "1.0.0",
    "params": [
      {
        "key": "approverRole",
        "label": "Onaylayan rol",
        "type": "string",
        "default": "manager",
        "tenantEditable": true
      }
    ],
    "rules": [
      {
        "id": "rs-approval-submit",
        "event": "task.submitted",
        "when": [],
        "then": {
          "type": "create-task",
          "params": { "title": "Onay bekliyor", "assignTo": "manager" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      },
      {
        "id": "rs-approval-approved",
        "event": "task.approved",
        "when": [{ "field": "approved", "op": "eq", "value": true }],
        "then": { "type": "set-field", "params": { "field": "status", "value": "in-progress" } },
        "maxChainDepth": 6,
        "requiresApproval": true
      }
    ],
    "safety": {
      "mutates": true,
      "requiresApproval": true,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": [], "levels": [] }
  },
  {
    "id": "rs-dunning-reminder",
    "name": "Tahsilat Hatırlatma (Dunning)",
    "description": "Vadesi geçen fatura için kademeli hatırlatma dizisi yürütür. Tenant kademeleri ayarlayabilir.",
    "layer": "tenant",
    "category": "escalation",
    "version": "1.0.0",
    "params": [
      {
        "key": "firstReminderDays",
        "label": "İlk hatırlatma (gün)",
        "type": "number",
        "default": 3,
        "tenantEditable": true
      },
      {
        "key": "finalReminderDays",
        "label": "Son hatırlatma (gün)",
        "type": "number",
        "default": 14,
        "tenantEditable": true
      }
    ],
    "rules": [
      {
        "id": "rs-dunning-overdue",
        "event": "invoice.overdue",
        "when": [{ "field": "daysOverdue", "op": "gte", "value": 3 }],
        "then": {
          "type": "notify",
          "params": { "target": "customer", "message": "Ödeme hatırlatması" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": false,
      "requiresApproval": false,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": ["finance", "customer-revenue"], "levels": [] }
  },
  {
    "id": "rs-onboarding-provision",
    "name": "İşe Başlatma Provizyonu",
    "description": "İşe alım tamamlandığında onboarding görevlerini, hesap/erişimi ve zorunlu eğitimi oluşturur. İdempotent.",
    "layer": "tenant",
    "category": "lifecycle",
    "version": "1.0.0",
    "params": [
      {
        "key": "templateByRole",
        "label": "Role göre görev şablonu",
        "type": "boolean",
        "default": true,
        "tenantEditable": true
      }
    ],
    "rules": [
      {
        "id": "rs-onboarding-hire-done",
        "event": "hire.completed",
        "when": [],
        "then": {
          "type": "create-task",
          "params": { "title": "Onboarding görevleri", "bundle": "onboarding" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": true,
      "requiresApproval": false,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": ["hr"], "levels": [] }
  },
  {
    "id": "rs-payroll-period-close",
    "name": "Bordro Dönem Kapanışı",
    "description": "Bordro dönemi geldiğinde hesaplar ve onaya gönderir. Görev ayrılığı (SoD): hesaplayan onaylayamaz; uygula insan onaylı.",
    "layer": "tenant",
    "category": "approval",
    "version": "1.0.0",
    "params": [],
    "rules": [
      {
        "id": "rs-payroll-period",
        "event": "payroll.period.due",
        "when": [],
        "then": {
          "type": "create-task",
          "params": { "title": "Bordro hesapla ve onaya gönder", "sod": true }
        },
        "maxChainDepth": 6,
        "requiresApproval": true
      }
    ],
    "safety": {
      "mutates": true,
      "requiresApproval": true,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": ["hr", "finance"], "levels": [] }
  },
  {
    "id": "rs-webhook-retry",
    "name": "Webhook Yeniden Deneme",
    "description": "Dış servis çağrısı başarısız olduğunda üstel geri-çekilmeyle yeniden dener; eşikte devre keser ve uyarır.",
    "layer": "platform",
    "category": "integration",
    "version": "1.0.0",
    "params": [
      {
        "key": "maxRetries",
        "label": "En çok deneme",
        "type": "number",
        "default": 5,
        "tenantEditable": false
      }
    ],
    "rules": [
      {
        "id": "rs-webhook-retry-fail",
        "event": "external.call.failed",
        "when": [{ "field": "retries", "op": "lt", "value": 5 }],
        "then": { "type": "retry", "params": { "backoff": "exponential" } },
        "maxChainDepth": 6,
        "requiresApproval": false
      },
      {
        "id": "rs-webhook-circuit-break",
        "event": "external.call.failed",
        "when": [{ "field": "retries", "op": "gte", "value": 5 }],
        "then": {
          "type": "notify",
          "params": { "target": "ops", "message": "Devre kesildi; dış servis erişilemez" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": false,
      "requiresApproval": false,
      "aiCanModify": true,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": ["scale", "platform-horizontal", "backend"], "levels": [] }
  },
  {
    "id": "rs-audit-on-change",
    "name": "Değişiklikte Denetim İzi",
    "description": "Hassas alan değiştiğinde değişmez denetim izi yazar. SYSTEM katmanı: AI değiştiremez, her zaman açık.",
    "layer": "system",
    "category": "audit",
    "version": "1.0.0",
    "params": [],
    "rules": [
      {
        "id": "rs-audit-sensitive-change",
        "event": "record.field.changed",
        "when": [{ "field": "sensitive", "op": "eq", "value": true }],
        "then": { "type": "audit-log", "params": { "immutable": true } },
        "maxChainDepth": 6,
        "requiresApproval": false
      }
    ],
    "safety": {
      "mutates": true,
      "requiresApproval": false,
      "aiCanModify": false,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": [], "levels": [] }
  },
  {
    "id": "rs-migration-guard",
    "name": "Göç Koruması",
    "description": "Veri göçü istendiğinde snapshot + geri-alma + uyumluluk kontrolü zorunlu kılar. SYSTEM katmanı: insan onaylı, AI değiştiremez.",
    "layer": "system",
    "category": "migration",
    "version": "1.0.0",
    "params": [],
    "rules": [
      {
        "id": "rs-migration-guard-require",
        "event": "data.migration.requested",
        "when": [{ "field": "snapshotCreated", "op": "eq", "value": false }],
        "then": {
          "type": "deny",
          "params": { "reason": "Snapshot/rollback/uyumluluk kontrolü gerekli" }
        },
        "maxChainDepth": 6,
        "requiresApproval": true
      }
    ],
    "safety": {
      "mutates": false,
      "requiresApproval": true,
      "aiCanModify": false,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": [], "levels": [] }
  },
  {
    "id": "rs-ai-boundary-gate",
    "name": "AI Yetki Sınırı Kapısı",
    "description": "AI aktörü app/module üretmeye/güncellemeye veya ruleset override etmeye kalkarsa reddeder; diğer mutasyonlar insan onayı ister. SYSTEM katmanı, AI değiştiremez.",
    "layer": "system",
    "category": "ai-boundary",
    "version": "1.0.0",
    "params": [],
    "rules": [
      {
        "id": "rs-ai-boundary-deny-appmodule",
        "event": "agent.action.requested",
        "when": [
          {
            "field": "action",
            "op": "in",
            "value": ["generate-app", "generate-module", "override-ruleset", "direct-prod-write"]
          }
        ],
        "then": {
          "type": "deny",
          "params": { "reason": "AI app/module üretemez veya ruleset override edemez" }
        },
        "maxChainDepth": 6,
        "requiresApproval": false
      },
      {
        "id": "rs-ai-boundary-stepup-mutation",
        "event": "agent.action.requested",
        "when": [
          { "field": "actor", "op": "eq", "value": "ai" },
          { "field": "mutating", "op": "eq", "value": true }
        ],
        "then": { "type": "require-approval", "params": { "approver": "human" } },
        "maxChainDepth": 6,
        "requiresApproval": true
      }
    ],
    "safety": {
      "mutates": false,
      "requiresApproval": true,
      "aiCanModify": false,
      "maxChainDepth": 6
    },
    "appliesTo": { "clusters": [], "levels": [] }
  }
]
