{
  "name": "actionplan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Stratejik Eylem Planı + Görev Yönetimi çerçevesi — JSON-as-DB, frontend-only, mobile-first.",
  "scripts": {
    "ingest": "node tools/ingest/index.mjs",
    "gen": "node tools/ingest/index.mjs",
    "gen:reindex": "node tools/reindex.mjs",
    "gen:deps": "node tools/derive-deps.mjs",
    "gen:fill": "node tools/fill-dimensions.mjs",
    "gen:items": "node tools/gen-items.mjs",
    "gen:prompts": "node tools/gen-prompts.mjs",
    "gen:rules": "node tools/gen-rules.mjs",
    "gen:audit": "node tools/audit.mjs",
    "qa:lint": "node tools/quality-lint.mjs",
    "agents:swarm": "node tools/agents/run-swarm.mjs",
    "agents:seed": "node tools/agents/seed-kernel.mjs",
    "dev": "vite",
    "build": "vite build && node tools/spa404.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:content": "vitest run --config vitest.content.config.ts",
    "qa:diagnose": "node tools/qa-agent.mjs",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@fontsource/roboto": "^5.1.0",
    "@hookform/resolvers": "^3.9.1",
    "@phosphor-icons/react": "^2.1.7",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.92.0",
    "@tanstack/react-table": "^8.20.6",
    "@xyflow/react": "^12.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^5.5.1",
    "elkjs": "^0.9.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
